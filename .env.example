# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (Primary Provider)
OPENAI_API_KEY=sk-...

# Anthropic (Fallback Provider)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Secondary Fallback Provider)
GOOGLE_API_KEY=...
GOOGLE_PROJECT_ID=your-project-id

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Local / staging ONLY: skip claim_letters payment checks in Netlify functions.
# Must be the string "true". Never set in production.
# BYPASS_PAYMENT_WALL=true

# Site Configuration
SITE_URL=https://insuranceclaimletterhelp.com

# Parity Layer Configuration
PARITY_ENABLED=false
PARITY_OPENAI_ENABLED=true
PARITY_ANTHROPIC_ENABLED=false
PARITY_GOOGLE_ENABLED=false
PARITY_AUTO_FAILOVER=true
PARITY_COST_OPTIMIZATION=false
PARITY_HEALTH_CHECKS=false
PARITY_CIRCUIT_BREAKER=false
PARITY_ROLLOUT_PERCENTAGE=0

# SendGrid (Email)
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@insuranceclaimletterhelp.com

# Admin — same secret for /admin-setup.html and /admin-login.html (plus password you choose at setup)
ADMIN_ACCESS_KEY=use-a-long-random-string-here
# Legacy alias (optional): read if ADMIN_ACCESS_KEY is unset
# ADMIN_SETUP_KEY=
# Email stored for the primary admin row (optional)
ADMIN_EMAIL=admin@insuranceclaimletterhelp.com
